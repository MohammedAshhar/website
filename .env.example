# Admin credentials (set your own passwords)
ADMIN_USER=admin
ADMIN_PASS=<your-admin-password-here>

# Owner credentials (LIMS owner — higher privileges)
OWNER_USER=owner
OWNER_PASS=<your-owner-password-here>

# Deskmanager credentials (lowest privileges — owner controls permissions)
DESK_USER=deskmanager
DESK_PASS=<your-desk-password-here>

# Optional: Google Sheets service account key path
# GOOGLE_SHEETS_CREDS_PATH=/path/to/service-account.json

# Optional: server port (default 3000)
# PORT=3000
